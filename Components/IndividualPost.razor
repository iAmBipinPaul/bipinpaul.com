@using BlazorStatic
@using System.Globalization
@using BlazorStatic.Services
@using System.Text.RegularExpressions
@inject BlazorStaticContentService<BlogFrontMatter> blazorStaticContentService

<HeadContent>
    @if (post is not null)
    {
        var firstImageUrl = ExtractFirstImageUrl(post.HtmlContent);
        var absoluteImageUrl = !string.IsNullOrEmpty(firstImageUrl) ? (WebsiteKeys.BlogPostUrl + "/" + firstImageUrl).ToString() : null;

        <title>@post.FrontMatter.Title</title>
        <meta name="description" content="@post.FrontMatter.Lead"/>
        <meta name="keywords" content="@string.Join(", ", post.FrontMatter.Tags)"/>
        <meta name="author" content="@string.Join(", ", post.FrontMatter.Authors.Select(a => a.Name))"/>

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="article"/>
        <meta property="og:title" content="@post.FrontMatter.Title"/>
        <meta property="og:description" content="@post.FrontMatter.Lead"/>
        <meta property="og:url" content="@(WebsiteKeys.BlogPostUrl + "/" + post.Url)"/>
        @if (!string.IsNullOrEmpty(absoluteImageUrl))
        {
            <meta property="og:image" content="@absoluteImageUrl"/>
        }

        <meta property="article:published_time" content="@post.FrontMatter.Published.ToString("o", CultureInfo.InvariantCulture)"/>
        @foreach (var author in post.FrontMatter.Authors)
        {
            <meta property="article:author" content="@author.Name"/>
        }

        @foreach (var tag in post.FrontMatter.Tags)
        {
            <meta property="article:tag" content="@tag"/>
        }

        <!-- Twitter -->
        <meta name="twitter:card" content="@(string.IsNullOrEmpty(absoluteImageUrl) ? "summary" : "summary_large_image")"/>
        <meta name="twitter:title" content="@post.FrontMatter.Title"/>
        <meta name="twitter:description" content="@post.FrontMatter.Lead"/>
        @if (!string.IsNullOrEmpty(absoluteImageUrl))
        {
            <meta name="twitter:image" content="@absoluteImageUrl"/>
        }

        <!-- Article structured data -->
        <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "Article",
          "headline": "@post.FrontMatter.Title",
          "description": "@post.FrontMatter.Lead",
          "datePublished": "@post.FrontMatter.Published.ToString("o", CultureInfo.InvariantCulture)",
          "author": {
            "@@type": "Person",
            "name": "@post.FrontMatter.Authors.FirstOrDefault()?.Name"
          },
          @(absoluteImageUrl != null ? $"\"image\": \"{absoluteImageUrl}\"," : "")
          "publisher": {
            "@@type": "Organization",
            "name": "Bipin Paul",
            "url": "@WebsiteKeys.BlogPostUrl"
          }
        }
        </script>
    }
</HeadContent>

<article class="article-shell">
    <!-- Compact Header -->
    <header class="article-header mb-8">
        <div class="space-y-4">
            <!-- Date and Reading Time -->
            <div class="flex items-center justify-between text-sm flex-wrap gap-2">
                <time datetime="@post.FrontMatter.Published.ToString("yyyy-MM-ddTHH:mm:ss.fffK", CultureInfo.InvariantCulture)"
                      class="text-foreground-muted font-medium">
                    @post.FrontMatter.Published.ToString("MMMM d, yyyy", new CultureInfo("en-US"))
                </time>
                <span class="inline-flex items-center gap-2 text-foreground-muted">
                    <div class="meta-icon">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <span class="font-medium">@ReadingTime min read</span>
                </span>
            </div>

            <!-- Title -->
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground leading-tight">
                @post.FrontMatter.Title
            </h1>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
                @foreach (var tag in post.FrontMatter.Tags)
                {
                    <a class="skill-tag text-xs uppercase tracking-wide hover:scale-105 transition-transform duration-200" href="@blazorStaticContentService.Options.Tags.TagsPageUrl/@tag">
                        @tag
                    </a>
                }
            </div>

            <!-- Author Section & Quick Actions -->
            <div class="author-actions-container pt-2">
                <!-- Left side: Author Info -->
                <div class="flex items-center space-x-4">
                    @foreach (var author in post.FrontMatter.Authors)
                    {
                        <div class="flex items-center space-x-3">
                            <div class="flex items-center space-x-3">
                                <span class="text-sm font-medium text-foreground-tertiary">@author.Name</span>

                                <!-- Social links -->
                                <div class="flex items-center space-x-2">
                                    @if (!string.IsNullOrWhiteSpace(author.XUserName))
                                    {
                                        <a target="_blank" rel="noopener noreferrer"
                                           href="https://x.com/@author.XUserName"
                                           class="article-meta-link"
                                           title="@author.Name on X">
                                            <Svg SizeClasses="w-4 h-4" Icon="Svg.Icons.X"/>
                                        </a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(author.GitHubUserName))
                                    {
                                        <a target="_blank" rel="noopener noreferrer"
                                           href="https://github.com/@author.GitHubUserName"
                                           class="article-meta-link"
                                           title="@author.Name on GitHub">
                                            <Svg SizeClasses="w-4 h-4" Icon="Svg.Icons.Github"/>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Right side: Quick Actions -->
                <div class="article-actions">
                    <a target="_blank" rel="noopener noreferrer"
                       href="@($"{WebsiteKeys.BlogPostStorageAddress}/{FileName}.md")"
                       class="article-meta-link">
                        <Svg SizeClasses="w-4 h-4" Icon="Svg.Icons.Github"/>
                        <span>Edit on GitHub</span>
                    </a>
                    <a href="/blog"
                       class="article-meta-link">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        <span>Back to blog</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <div class="article-surface p-6 md:p-8 max-w-none">
        <main>
            <div class="max-w-none">
                <div class="blog-content">
                    @((MarkupString)post.HtmlContent)
                </div>
            </div>
        </main>
    </div>

    <!-- Prev/Next Navigation -->
    @if (prevPost != null || nextPost != null)
    {
        <div class="mt-10 pt-8 border-t border-border">
            <div class="grid gap-4 md:grid-cols-2">
                @if (prevPost != null)
                {
                    <a href="@blazorStaticContentService.Options.PageUrl/@(prevPost.Url)" class="group block p-5 rounded-xl border border-border bg-surface hover:border-accent/30 hover:shadow-lg transition-all duration-200">
                        <div class="flex items-center gap-2 text-xs text-foreground-muted mb-2">
                            <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                            </svg>
                            <span class="font-semibold uppercase tracking-wider">Previous</span>
                        </div>
                        <h3 class="text-base font-bold text-foreground line-clamp-2 group-hover:text-accent transition-colors">@prevPost.FrontMatter.Title</h3>
                        <time class="mt-1 block text-sm text-foreground-muted">@prevPost.FrontMatter.Published.ToString("MMM d, yyyy", new CultureInfo("en-US"))</time>
                    </a>
                }
                else
                {
                    <div class="hidden md:block"></div>
                }
                @if (nextPost != null)
                {
                    <a href="@blazorStaticContentService.Options.PageUrl/@(nextPost.Url)" class="group block p-5 rounded-xl border border-border bg-surface hover:border-accent/30 hover:shadow-lg transition-all duration-200 md:text-right">
                        <div class="flex items-center gap-2 text-xs text-foreground-muted mb-2 md:justify-end">
                            <span class="font-semibold uppercase tracking-wider">Next</span>
                            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </div>
                        <h3 class="text-base font-bold text-foreground line-clamp-2 group-hover:text-accent transition-colors">@nextPost.FrontMatter.Title</h3>
                        <time class="mt-1 block text-sm text-foreground-muted">@nextPost.FrontMatter.Published.ToString("MMM d, yyyy", new CultureInfo("en-US"))</time>
                    </a>
                }
            </div>
        </div>
    }

    <script src="https://giscus.app/client.js"
            data-repo="iambipinpaul/bipinpaul.com"
            data-repo-id="MDEwOlJlcG9zaXRvcnkxNTc5NjI3ODI="
            data-category="Announcements"
            data-category-id="DIC_kwDOCWpSHs4CtZNi"
            data-mapping="og:title"
            data-strict="1"
            data-reactions-enabled="1"
            data-emit-metadata="1"
            data-input-position="top"
            data-theme="preferred_color_scheme"
            data-lang="en"
            crossorigin="anonymous"
            async>
    </script>
</article>

@code {
    [Parameter] public string? FileName { get; set; }
    [Parameter] public Post<BlogFrontMatter> post { get; set; } = default!;

    private Post<BlogFrontMatter>? prevPost;
    private Post<BlogFrontMatter>? nextPost;

    protected override void OnInitialized()
    {
        if (post == null) return;

        var sortedPosts = blazorStaticContentService.Posts
            .OrderByDescending(p => p.FrontMatter.Published)
            .ToList();

        var currentIndex = sortedPosts.FindIndex(p => p.Url == post.Url);
        if (currentIndex > 0)
            prevPost = sortedPosts[currentIndex - 1];
        if (currentIndex < sortedPosts.Count - 1)
            nextPost = sortedPosts[currentIndex + 1];
    }

    private int ReadingTime
    {
        get
        {
            if (post == null) return 0;
            var text = StripHtml(post.HtmlContent);
            var wordCount = text.Split(new[] { ' ', '\t', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Length;
            return Math.Max(1, (int)Math.Ceiling(wordCount / 225.0));
        }
    }

    private string StripHtml(string html)
    {
        if (string.IsNullOrEmpty(html)) return string.Empty;
        var text = Regex.Replace(html, "<[^>]+>", string.Empty);
        text = Regex.Replace(text, @"&\w+;", " ");
        return text;
    }

    private string? ExtractFirstImageUrl(string htmlContent)
    {
        if (string.IsNullOrEmpty(htmlContent))
            return null;

        var match = Regex.Match(htmlContent, "<img[^>]+src=\"([^\"]+)\"[^>]*>", RegexOptions.IgnoreCase);
        if (match.Success && match.Groups.Count > 1)
        {
            return match.Groups[1].Value;
        }

        return null;
    }

}
