@page "/"


<HeadContent>
    <title>Bipin Paul | iAmBipinPaul | .NET, Blazor, Azure</title>
    <meta name="description" content="Personal site of Bipin Paul (iAmBipinPaul): Nepal-based software engineer focused on ASP.NET Core, Blazor, Azure, cloud delivery, and dependable product engineering."/>
    <meta name="keywords" content="Bipin Paul, iAmBipinPaul, .NET, C#, ASP.NET Core, Blazor, Azure, Cloud, Developer, Docker, Cosmos DB, SQL Server, Entity Framework Core, Nepal"/>
    <meta name="author" content="Bipin Paul"/>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website"/>
    <meta property="og:title" content="Bipin Paul | .NET, Blazor, Azure"/>
    <meta property="og:description" content="Nepal-based software engineer building dependable .NET, Blazor, and cloud systems."/>
    <meta property="og:image" content="@(@WebsiteKeys.BlogPostUrl + "/" + "images/bipinpaul.jpeg")"/>
    <meta property="og:url" content="@WebsiteKeys.BlogPostUrl"/>

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="Bipin Paul | .NET, Blazor, Azure"/>
    <meta name="twitter:description" content="Nepal-based software engineer building dependable .NET, Blazor, and cloud systems."/>
    <meta name="twitter:image" content="@(@WebsiteKeys.BlogPostUrl + "/" + "images/bipinpaul.jpeg")"/>
</HeadContent>

<div class="py-8 lg:py-12 space-y-16">
    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.7fr)_minmax(320px,0.9fr)] lg:items-start">
        <div class="hero-shell glass-card p-6 md:p-8 lg:p-10">
            <p class="section-kicker">Software engineer based in Nepal</p>

            <div class="space-y-6">
                <h1 class="max-w-3xl text-4xl font-extrabold tracking-tight text-foreground lg:text-[3.45rem] lg:leading-[1.02] xl:text-[3.7rem]">
                    I build <span class="text-foreground">.NET, Blazor, and Azure</span> applications.
                </h1>

                <p class="max-w-2xl text-lg leading-8 text-foreground-secondary lg:text-[1.1rem]">
                    I work across backend systems, web apps, and cloud delivery, with most of my day-to-day work centered on ASP.NET Core and Blazor.
                </p>

                <div class="flex flex-wrap gap-2 text-sm text-foreground-secondary">
                    <span class="skill-tag text-xs">ASP.NET Core</span>
                    <span class="skill-tag text-xs">Blazor</span>
                    <span class="skill-tag text-xs">Azure</span>
                    <span class="skill-tag text-xs">Entity Framework Core</span>
                    <span class="skill-tag-muted text-xs">.NET Foundation member</span>
                </div>

                <div class="flex flex-wrap gap-3 pt-1">
                    <a href="/blog" class="btn-primary inline-flex items-center gap-2">
                        <span>Read the blog</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                    <a href="@WebsiteKeys.GitHubProfile" target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-2 rounded-xl border border-border bg-white/5 px-5 py-3 font-medium text-foreground-secondary transition-all duration-200 hover:border-white/10 hover:bg-white/6 hover:text-foreground">
                        <Svg Icon="Svg.Icons.Github" SizeClasses="w-4 h-4"/>
                        <span>GitHub profile</span>
                    </a>
                </div>

                <div class="grid gap-3 pt-4 sm:grid-cols-3">
                    <div class="metric-card">
                        <span class="metric-card-value">7+</span>
                        <p class="metric-card-label">years in production software</p>
                    </div>
                    <div class="metric-card">
                        <span class="metric-card-value">Backend-first</span>
                        <p class="metric-card-label">APIs, integrations, and cloud systems</p>
                    </div>
                    <div class="metric-card">
                        <span class="metric-card-value">Writing</span>
                        <p class="metric-card-label">Notes and articles from real work</p>
                    </div>
                </div>
            </div>
        </div>

        <aside class="profile-rail p-6 lg:sticky lg:top-28">
            <div class="flex items-center gap-4">
                <img src="images/bipinpaul.jpeg" alt="Bipin Paul"
                     class="h-20 w-20 rounded-2xl object-cover border border-border shadow-xl"/>
                <div>
                    <p class="text-lg font-semibold text-foreground">Bipin Paul</p>
                    <p class="text-sm text-foreground-secondary">@WebsiteKeys.Username</p>
                    <p class="text-sm text-foreground-muted">Janakpur • Kathmandu • Nepal</p>
                </div>
            </div>

            <div class="mt-6 space-y-2 border-t border-border pt-5 text-sm text-foreground-secondary">
                <p>.NET-focused engineer with an interest in clean systems and practical delivery.</p>
            </div>

            <div class="mt-6 space-y-3">
                <a class="platform-link" href="@WebsiteKeys.GitHubProfile" target="_blank" rel="noopener noreferrer">
                    <span>GitHub</span>
                    <span class="text-foreground-muted">@WebsiteKeys.Username</span>
                </a>
                <a class="platform-link" href="@WebsiteKeys.X" target="_blank" rel="noopener noreferrer">
                    <span>X</span>
                    <span class="text-foreground-muted">@@iAmBipinPaul</span>
                </a>
                <a class="platform-link" href="@WebsiteKeys.LinkedIn" target="_blank" rel="noopener noreferrer">
                    <span>LinkedIn</span>
                    <span class="text-foreground-muted">/in/iambipinpaul</span>
                </a>
                <a class="platform-link" href="@WebsiteKeys.Bluesky" target="_blank" rel="noopener noreferrer">
                    <span>Bluesky</span>
                    <span class="text-foreground-muted">bipinpaul.com</span>
                </a>
            </div>

        </aside>
    </section>

    <section class="border-t border-border pt-12">
        <div class="max-w-2xl">
            <p class="section-kicker">Focus</p>
            <h2 class="text-3xl font-bold text-foreground lg:text-4xl">Core areas I spend time in.</h2>
        </div>

        <div class="mt-8 grid gap-6 md:grid-cols-2">
            <div class="glass-card p-6">
                <p class="section-kicker mb-3">Core stack</p>
                <h3 class="text-2xl font-semibold text-foreground">ASP.NET Core and Blazor</h3>
                <p class="mt-3 text-foreground-tertiary">APIs, application logic, and product-facing web applications.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                    <span class="skill-tag text-xs">ASP.NET Core</span>
                    <span class="skill-tag text-xs">Blazor</span>
                    <span class="skill-tag text-xs">C#</span>
                    <span class="skill-tag text-xs">Minimal APIs</span>
                </div>
            </div>

            <div class="glass-card p-6">
                <p class="section-kicker mb-3">Cloud and integration</p>
                <h3 class="text-2xl font-semibold text-foreground">Azure and delivery</h3>
                <p class="mt-3 text-foreground-tertiary">I regularly work with Azure services, containers, messaging, and CI/CD.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                    <span class="skill-tag-primary text-xs">Azure Functions</span>
                    <span class="skill-tag-primary text-xs">Service Bus</span>
                    <span class="skill-tag-primary text-xs">Cosmos DB</span>
                    <span class="skill-tag-primary text-xs">Docker</span>
                </div>
            </div>

            <div class="glass-card p-6">
                <p class="section-kicker mb-3">Data and persistence</p>
                <h3 class="text-2xl font-semibold text-foreground">Structured data</h3>
                <p class="mt-3 text-foreground-tertiary">Most projects involve relational data, EF Core, and predictable persistence.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                    <span class="skill-tag-pink text-xs">SQL Server</span>
                    <span class="skill-tag-pink text-xs">PostgreSQL</span>
                    <span class="skill-tag-pink text-xs">Entity Framework Core</span>
                    <span class="skill-tag-pink text-xs">Cosmos DB</span>
                </div>
            </div>

            <div class="glass-card p-6">
                <p class="section-kicker mb-3">Writing and OSS</p>
                <h3 class="text-2xl font-semibold text-foreground">Writing and open source</h3>
                <p class="mt-3 text-foreground-tertiary">I write about patterns, experiments, and implementation details worth keeping.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                    <span class="skill-tag text-xs">Technical blogging</span>
                    <span class="skill-tag text-xs">Open source</span>
                    <span class="skill-tag text-xs">Sample apps</span>
                    <span class="skill-tag text-xs">Developer education</span>
                </div>
            </div>
        </div>
    </section>

    <section class="border-t border-border pt-12">
        <div class="text-center mb-10">
            <p class="section-kicker mb-3">Latest writing</p>
            <h2 class="text-2xl font-extrabold text-foreground sm:text-3xl md:text-4xl mb-3">Recent writing</h2>
            <p class="text-foreground-muted">
                Notes from projects, experiments, and day-to-day engineering work.
            </p>
        </div>

        <PostsList MaxPosts="3"/>

        <div class="flex justify-center pt-10">
            <a href="/blog"
               class="group inline-flex items-center gap-2 rounded-lg border border-border bg-white/5 px-6 py-3 font-medium text-foreground-secondary transition-all duration-200 hover:border-white/10 hover:bg-white/6 hover:text-foreground">
                <span>View all blog posts</span>
                <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </section>
</div>
