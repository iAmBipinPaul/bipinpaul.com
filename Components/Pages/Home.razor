@page "/"

<HeadContent>
    <title>Bipin Paul | .NET &amp; Cloud Engineer</title>
    <meta name="description" content="Bipin Paul (iambipinpaul) is a .NET developer building backend systems, APIs, and web applications with C#, ASP.NET Core, Blazor, Azure, and Google Cloud."/>
    <meta name="keywords" content="Bipin Paul, iambipinpaul, .NET, C#, ASP.NET Core, Blazor, Azure, Google Cloud, Docker, GitHub Actions, Azure Pipelines, SQL Server, PostgreSQL, Cosmos DB, Entity Framework Core, Nepal"/>
    <meta name="author" content="Bipin Paul"/>
    <link rel="canonical" href="@WebsiteKeys.BlogPostUrl"/>

    <meta property="og:type" content="profile"/>
    <meta property="og:title" content="Bipin Paul | .NET &amp; Cloud Engineer"/>
    <meta property="og:description" content=".NET developer building backend systems, APIs, and web applications."/>
    <meta property="og:image" content="@(@WebsiteKeys.BlogPostUrl + "/" + "images/bipinpaul.jpeg")"/>
    <meta property="og:url" content="@WebsiteKeys.BlogPostUrl"/>
    <meta property="og:site_name" content="Bipin Paul"/>

    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="Bipin Paul | .NET &amp; Cloud Engineer"/>
    <meta name="twitter:description" content=".NET developer building backend systems, APIs, and web applications."/>
    <meta name="twitter:image" content="@(@WebsiteKeys.BlogPostUrl + "/" + "images/bipinpaul.jpeg")"/>

    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "Person",
      "@@id": "https://bipinpaul.com/#bipin-paul",
      "name": "Bipin Paul",
      "alternateName": "iambipinpaul",
      "url": "https://bipinpaul.com",
      "image": "https://bipinpaul.com/images/bipinpaul.jpeg",
      "jobTitle": ".NET and Azure Cloud Engineer",
      "address": {
        "@@type": "PostalAddress",
        "addressCountry": "NP"
      },
      "knowsAbout": [
        "ASP.NET Core",
        "Blazor",
        "C#",
        "Azure",
        "Docker",
        "GitHub Actions",
        "Azure Pipelines",
        "Entity Framework Core",
        "SQL Server",
        "PostgreSQL",
        "Cosmos DB"
      ],
      "sameAs": [
        "https://github.com/iambipinpaul",
        "https://www.linkedin.com/in/iambipinpaul",
        "https://x.com/iambipinpaul",
        "https://dev.to/iambipinpaul"
      ]
    }
    </script>
</HeadContent>

@* ================ HERO ================ *@
<header class="hero-section">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.45fr)_minmax(280px,1fr)] lg:items-center">
        <div>
            <span class="eyebrow">
                <span class="eyebrow-dot"></span>
                <span>Independent .NET &amp; Cloud Engineer</span>
            </span>

            <h1 class="hero-title mt-6">
                I build .NET applications 
                <span class="hero-subtitle">and cloud infrastructure.</span>
            </h1>

            <p class="hero-lead">
                I'm a .NET developer. I build backend systems, APIs, and web applications using C#, ASP.NET Core, and Blazor. I also handle containerization and cloud infrastructure on both Azure and Google Cloud.
            </p>

            <div class="mt-7 flex flex-wrap gap-3">
                <a href="@WebsiteKeys.GitHubProfile" target="_blank" rel="noopener noreferrer" class="btn-primary">
                    <Svg Icon="Svg.Icons.Github" SizeClasses="w-4 h-4"/>
                    <span>See work on GitHub</span>
                </a>
                <a href="/blog" class="btn-secondary">
                    <span>Read the blog</span>
                </a>
                <a href="#resume" class="ak-action-link">
                    <span>Open resume</span>
                    <span class="ak-action-link-arrow" aria-hidden="true">&rarr;</span>
                </a>
            </div>
        </div>

        <aside class="identity-summary">
            <div class="flex items-center gap-4">
                <div class="identity-summary-photo">
                    <img src="images/bipinpaul.jpeg" alt="Bipin Paul" loading="lazy"/>
                </div>
                <div>
                    <p class="identity-summary-name">Bipin Paul</p>
                    <p class="identity-summary-handle">@@@WebsiteKeys.Username</p>
                </div>
            </div>

            <p class="identity-summary-role">
                .NET &amp; Cloud Engineer | C#, ASP.NET Core, Blazor | Azure &amp; Google Cloud
            </p>

            <div class="identity-summary-meta">
                <span>Kathmandu</span>
                <span class="identity-summary-meta-dot"></span>
                <span>Nepal</span>
                <span class="identity-summary-meta-dot"></span>
                <span>UTC+5:45</span>
            </div>

            <div class="identity-summary-links">
                <a class="identity-summary-link" href="@WebsiteKeys.GitHubProfile" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                    <Svg Icon="Svg.Icons.Github" SizeClasses="w-4 h-4"/>
                </a>
                <a class="identity-summary-link" href="@WebsiteKeys.LinkedIn" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    <Svg Icon="Svg.Icons.LinkedIn" SizeClasses="w-4 h-4"/>
                </a>
                <a class="identity-summary-link" href="@WebsiteKeys.X" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
                    <Svg Icon="Svg.Icons.X" SizeClasses="w-4 h-4"/>
                </a>
                <a class="identity-summary-link" href="@WebsiteKeys.DevTo" target="_blank" rel="noopener noreferrer" aria-label="DEV.to">
                    <span class="text-[0.62rem] font-extrabold tracking-tight">DEV</span>
                </a>
            </div>
        </aside>
    </div>

    @* Hero proof grid *@
    <div class="hero-proof-grid mt-12">
        <div class="hero-proof-card">
            <span class="hero-proof-meta">What I build</span>
            <span class="hero-proof-value">ERP &amp; QMS tools</span>
            <span class="hero-proof-label">Web-based business applications built with Blazor and ASP.NET Core.</span>
        </div>
        <div class="hero-proof-card">
            <span class="hero-proof-meta">Cloud</span>
            <span class="hero-proof-value">Azure &amp; Google Cloud</span>
            <span class="hero-proof-label">App Service, Container Apps, Service Bus, and Google Cloud Run.</span>
        </div>
        <div class="hero-proof-card">
            <span class="hero-proof-meta">DevOps</span>
            <span class="hero-proof-value">Containers &amp; CI/CD</span>
            <span class="hero-proof-label">Docker, GitHub Actions, and Azure Pipelines to automate testing and deployment.</span>
        </div>
    </div>
</header>

@* ================ FOUNDATION STRIP ================ *@
<section class="mt-10">
    <div class="ak-logo-strip">
        <div class="ak-logo-strip-inner">
            <span class="ak-logo-strip-label">Day-to-day stack</span>
            <ul class="ak-logo-strip-list">
                @foreach (var item in StackChips)
                {
                    <li class="ak-logo-strip-item">
                        <span class="logo-dot"></span>
                        <span>@item</span>
                    </li>
                }
            </ul>
        </div>
    </div>
</section>

@* ================ FOCUS AREAS ================ *@
<section class="ak-section">
    <div class="ak-section-header ak-section-header--center">
        <span class="ak-kicker-chip">What I focus on</span>
        <h2 class="ak-section-title">My core stack and focus.</h2>
        <p class="ak-section-subtitle">
            The technologies I use to build, deploy, and maintain applications.
        </p>
    </div>

    <div class="ak-info-tile-grid ak-info-tile-grid--3 mt-10">
        @foreach (var area in FocusAreas)
        {
            <article class="ak-info-tile">
                <span class="ak-info-tile-icon @area.IconClass">
                    @((MarkupString)area.IconSvg)
                </span>
                <h3 class="ak-info-tile-title">@area.Title</h3>
                <p class="ak-info-tile-description">@area.Description</p>
            </article>
        }
    </div>
</section>

@* ================ FEATURED PROJECT ================ *@
<section id="work" class="ak-section">
    <div class="ak-section-header ak-section-header--center">
        <span class="ak-kicker-chip">Open source &amp; public work</span>
        <h2 class="ak-section-title">Things I keep open on GitHub.</h2>
        <p class="ak-section-subtitle">
            Public repositories, sample apps, and a starter platform &mdash; the parts of my work that get to live in the open.
        </p>
    </div>

    <div class="ak-feature-showcase mt-12">
        <div class="ak-feature-showcase-copy">
            <span class="ak-feature-showcase-label">Featured &middot; Krafter</span>
            <h3 class="ak-feature-showcase-title">A modern .NET full-stack starter built like a real product.</h3>
            <p class="ak-feature-showcase-description">
                Krafter is a vertical-slice, multi-tenant .NET platform with a Blazor WebAssembly front-end. It's the opinionated starting point I keep reaching for when a new product needs to be honest about architecture, identity, and deployment from day one.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
                <span class="capability-chip">Vertical slice architecture</span>
                <span class="capability-chip">Multi-tenant</span>
                <span class="capability-chip">Blazor WebAssembly</span>
                <span class="capability-chip">.NET 10</span>
            </div>
            <div class="mt-7">
                <a href="https://github.com/AditiKraft/Krafter" target="_blank" rel="noopener noreferrer" class="btn-primary">
                    <Svg Icon="Svg.Icons.Github" SizeClasses="w-4 h-4"/>
                    <span>Open Krafter on GitHub</span>
                </a>
            </div>
        </div>

        <div class="ak-feature-showcase-visual">
            <figure class="capability-panel">
                <header>
                    <span class="capability-panel-eyebrow">Reference architecture</span>
                    <h3 class="capability-panel-title">A delivery surface that stays inspectable end to end.</h3>
                </header>
                <ul class="capability-list">
                    <li>
                        <span class="capability-lane">UI</span>
                        <div>
                            <strong>Blazor hybrid front-end</strong>
                            <span>Composable pages, typed clients, feature-aligned folders.</span>
                        </div>
                    </li>
                    <li>
                        <span class="capability-lane">API</span>
                        <div>
                            <strong>Minimal API slices</strong>
                            <span>Routes, validation, and handlers grouped by feature, not by layer.</span>
                        </div>
                    </li>
                    <li>
                        <span class="capability-lane">Data</span>
                        <div>
                            <strong>Migrations &amp; persistence</strong>
                            <span>Schema changes are checked in, applied automatically, reviewable.</span>
                        </div>
                    </li>
                    <li>
                        <span class="capability-lane">Ops</span>
                        <div>
                            <strong>Containers &amp; CI/CD</strong>
                            <span>Docker images and pipelines so production stays a routine event.</span>
                        </div>
                    </li>
                </ul>
            </figure>
        </div>
    </div>

    @* Other projects *@
    <div class="project-card-grid mt-12">
        @foreach (var project in OtherProjects)
        {
            <article class="project-card">
                <header class="project-card-header">
                    <span class="project-card-kind">@project.Kind</span>
                    <span class="project-card-lang">
                        <span class="project-card-lang-dot" style="background-color: @project.LanguageColor;"></span>
                        <span>@project.Language</span>
                    </span>
                </header>

                <h3 class="project-card-title">@project.Name</h3>
                <p class="project-card-description">@project.Description</p>

                <ul class="project-card-tags">
                    @foreach (var tag in project.Tags)
                    {
                        <li class="capability-chip">@tag</li>
                    }
                </ul>

                <footer class="project-card-footer">
                    <a href="@project.Url" target="_blank" rel="noopener noreferrer"
                       class="project-card-link" aria-label="View @project.Name on GitHub">
                        <Svg Icon="Svg.Icons.Github" SizeClasses="w-4 h-4"/>
                        <span>View on GitHub</span>
                        <span class="project-card-link-arrow" aria-hidden="true">&rarr;</span>
                    </a>
                </footer>
            </article>
        }
    </div>
</section>

@* ================ RESUME ================ *@
<section id="resume" class="ak-section">
    <div class="capability-panel">
        <div class="grid gap-6 md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
            <div>
                <span class="capability-panel-eyebrow">Resume</span>
                <h2 class="ak-section-title mt-2 !text-[1.6rem] md:!text-[2rem]">Professional background &amp; technical experience.</h2>
                <p class="mt-3 max-w-2xl text-foreground-secondary">
                    A concise PDF overview of my .NET, Azure, backend, data, and delivery work &mdash; written for hiring teams and technical reviewers.
                </p>
            </div>
            <div class="flex flex-wrap gap-3">
                <a href="@WebsiteKeys.ResumePreviewUrl" target="_blank" rel="noopener noreferrer" class="btn-primary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 3h6v6M14 10l7-7M19 14v6a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h6"/>
                    </svg>
                    <span>Open resume</span>
                </a>
                <a href="@WebsiteKeys.ResumeDownloadUrl" download="Bipin_Paul_Resume.pdf" class="btn-secondary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/>
                    </svg>
                    <span>Download PDF</span>
                </a>
            </div>
        </div>
    </div>
</section>

@* ================ WRITING ================ *@
<section class="ak-section">
    <div class="ak-section-header ak-section-header--center">
        <span class="ak-kicker-chip">Writing</span>
        <h2 class="ak-section-title">Recent posts.</h2>
        <p class="ak-section-subtitle">
            Practical .NET, Blazor, Azure, and implementation notes &mdash; written from real project work.
        </p>
    </div>

    <div class="mt-10">
        <PostsList MaxPosts="3"/>
    </div>

    <div class="mt-10 flex justify-center">
        <a href="/blog" class="ak-action-link">
            <span>View all blog posts</span>
            <span class="ak-action-link-arrow" aria-hidden="true">&rarr;</span>
        </a>
    </div>
</section>

