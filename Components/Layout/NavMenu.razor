@inject NavigationManager Nm

<header class="glass-nav sticky top-0 z-[100] mb-5 flex items-center justify-between gap-4 px-4 py-3 sm:top-4 sm:mt-4 sm:mb-0 sm:px-5 sm:py-4">
    <!-- Logo -->
    <div>
        <a href="" class="group inline-flex items-center gap-3">
            <span class="brand-mark">BP</span>
            <span>
                <span class="block text-sm font-semibold text-foreground transition-colors">@WebsiteKeys.Title</span>
                <span class="block text-xs text-foreground-muted">@WebsiteKeys.Username</span>
            </span>
        </a>
    </div>

    <!-- Desktop Navigation -->
    <nav class="hidden sm:flex items-center gap-1">
        @foreach (var item in menuItems)
        {
            @if (!string.IsNullOrEmpty(item.Name))
            {
                <NavLink ActiveClass="bg-white/6 text-foreground border-white/10"
                         class="px-4 py-2 rounded-lg font-medium text-foreground-secondary hover:text-foreground hover:bg-white/5 border border-transparent transition-all duration-200"
                         Match="@(item.Link == "" ? NavLinkMatch.All : NavLinkMatch.Prefix)" href="@item.Link">
                    @item.Name
                </NavLink>
            }
            else
            {
                <a href="@item.Link" target="_blank" rel="noopener noreferrer"
                   class="ml-2 p-2 rounded-lg text-foreground-muted hover:text-foreground hover:bg-white/5 border border-transparent hover:border-white/10 transition-all duration-200 icon-bounce">
                    <Svg Icon="item.Icon" SizeClasses="w-5 h-5"/>
                </a>
            }
        }
    </nav>

    <!-- Mobile Menu Button -->
    <button id="toggle-button" aria-label="Toggle Menu" class="sm:hidden p-2 rounded-lg hover:bg-white/5 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-8 w-8 text-foreground">
            <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path>
        </svg>
    </button>

</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="mobile-menu-overlay hidden sm:hidden">
    <div class="mx-auto min-h-screen max-w-3xl px-4 pt-4">
        <div class="flex justify-end">
            <button id="close-mobile-menu-button" class="p-2 rounded-lg hover:bg-white/5 transition-colors" aria-label="Close Menu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-8 h-8 text-foreground">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                </svg>
            </button>
        </div>

        <nav class="mobile-menu-panel mt-10 space-y-2 rounded-2xl border border-border p-6 shadow-2xl">
            @foreach (var item in menuItems)
            {
                @if (!string.IsNullOrEmpty(item.Name))
                {
                    <div class="py-2">
                        <NavLink ActiveClass="text-foreground"
                                 class="block text-3xl font-bold text-foreground-secondary transition-colors hover:text-foreground"
                                 Match="@(item.Link == "" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                                 href="@item.Link">
                            @item.Name
                        </NavLink>
                    </div>
                }
                else
                {
                    <div class="py-2">
                        <a href="@item.Link" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-3 text-foreground-muted transition-colors hover:text-foreground">
                            <Svg Icon="item.Icon" SizeClasses="w-6 h-6"/>
                            <span class="text-lg">@item.Label</span>
                        </a>
                    </div>
                }
            }
        </nav>
    </div>
</div>
<script>
    const toggleMobileMenu = () => document.querySelector('#mobile-menu').classList.toggle('hidden');

    document.querySelector('#toggle-button').addEventListener('click', toggleMobileMenu);
    document.querySelector('#close-mobile-menu-button').addEventListener('click', toggleMobileMenu);
</script>


@code
{
    List<MenuItem> menuItems =
    [
        new("Home", ""),
        new("Blog", "blog"),
        new("Tags", "tags"),
        new("", WebsiteKeys.GitHubProfile, Svg.Icons.Github, "GitHub"),
        new("", WebsiteKeys.LinkedIn, Svg.Icons.LinkedIn, "LinkedIn"),
        new("", WebsiteKeys.X, Svg.Icons.X, "X")
    ];

    record MenuItem(string Name, string Link, Svg.Icons? Icon = null, string? Label = null);
}
