@inherits LayoutComponentBase

<div class="min-h-screen site-shell">
    <div class="mx-auto w-full max-w-3xl px-4 sm:max-w-5xl sm:px-6 md:max-w-6xl lg:max-w-7xl lg:px-8 2xl:max-w-[92rem] relative z-10">
        <div class="flex min-h-screen flex-col justify-between">

            <NavMenu/>

            <main class="mb-auto">
                @Body
            </main>

            <footer>
                <div class="mt-16 section-divider pt-10 pb-8">
                    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
                        <div class="max-w-xl">
                             <p class="section-kicker mb-3">@WebsiteKeys.Title</p>
                             <p class="text-sm text-foreground-tertiary">
                                Practical notes on ASP.NET Core, Blazor, Azure, and implementation patterns.
                             </p>
                        </div>

                        <div class="flex items-center gap-5">
                            <a class="footer-social-link" target="_blank" rel="noopener noreferrer" href="@WebsiteKeys.GitHubProfile">
                                <span class="sr-only">github</span>
                                <Svg Icon="Svg.Icons.Github" SizeClasses="w-6 h-6"/>
                            </a>
                            <a class="footer-social-link" target="_blank" rel="noopener noreferrer" href="@WebsiteKeys.LinkedIn">
                                <span class="sr-only">linkedin</span>
                                <Svg Icon="Svg.Icons.LinkedIn" SizeClasses="w-6 h-6"/>
                            </a>
                            <a class="footer-social-link" target="_blank" rel="noopener noreferrer" href="@WebsiteKeys.X">
                                <span class="sr-only">x</span>
                                <Svg Icon="Svg.Icons.X" SizeClasses="w-6 h-6"/>
                            </a>
                            <a class="footer-social-link" target="_blank" rel="noopener noreferrer" href="@WebsiteKeys.DevTo">
                                <span class="sr-only">dev.to</span>
                                <span class="text-[0.7rem] font-extrabold tracking-tight">DEV</span>
                            </a>
                        </div>
                    </div>

                    <div class="mt-6 flex flex-col gap-2 text-sm text-foreground-muted sm:flex-row sm:items-center sm:justify-between">
                        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
                            <a target="_blank" rel="noopener noreferrer" href="https://github.com/BlazorStatic/BlazorStatic"
                               class="inline-accent-link inline-flex items-center gap-1">
                                <span>Built with</span>
                                <span class="font-medium">Blazor Static</span>
                            </a>
                            <span class="hidden sm:inline text-border-light">•</span>
                            <span>@WebsiteKeys.Tagline</span>
                        </div>

                        <span>© @DateTime.Now.Year Bipin Paul</span>
                    </div>
                </div>
            </footer>
        </div>
    </div>
</div>

<button id="scroll-to-top" class="scroll-to-top" aria-label="Scroll to top" title="Back to top">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
    </svg>
</button>

<script>
    (() => {
        const btn = document.getElementById('scroll-to-top');
        if (!btn) return;

        let visible = false;

        const toggle = () => {
            const shouldShow = window.scrollY > 400;
            if (shouldShow !== visible) {
                visible = shouldShow;
                btn.classList.toggle('scroll-to-top--visible', visible);
            }
        };

        btn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        window.addEventListener('scroll', toggle, { passive: true });
        toggle();
    })();
</script>
