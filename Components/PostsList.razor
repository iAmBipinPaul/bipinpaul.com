@using System.Globalization
@using BlazorStatic
@using BlazorStatic.Services
@inject BlazorStaticContentService<BlogFrontMatter> blazorStaticContentService
@inject BlazorStaticService blazorStaticService

<ul class="space-y-6">
    @{ var index = 0; }
    @foreach (var post in posts)
    {
        var firstImageUrl = ExtractFirstImageUrl(post.HtmlContent);
        var delay = index * 100;
        <li class="group" style="animation-delay: @(delay)ms">
            <article class="glass-card post-list-card hover-lift p-6">
                <!-- Gradient accent on hover -->
                <div class="post-card-accent"></div>

                <div class="flex flex-col lg:flex-row lg:gap-8">
                    <!-- Image Section -->
                    <div class="mb-4 lg:mb-0 lg:w-1/4 flex-shrink-0">
                        @if (!string.IsNullOrEmpty(firstImageUrl))
                        {
                            <div class="post-image-frame aspect-video lg:aspect-[4/3] relative">
                                <img src="@firstImageUrl"
                                     alt="@post.FrontMatter.Title"
                                     class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"/>
                                <div class="absolute inset-0 bg-gradient-to-t from-background/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            </div>
                        }
                        else
                        {
                            <div class="post-image-frame post-fallback aspect-video lg:aspect-[4/3]">
                                <svg class="w-10 h-10 text-foreground-muted/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                                </svg>
                            </div>
                        }

                        <!-- Date and Reading Time -->
                        <div class="mt-3 flex items-center gap-3 text-xs text-foreground-muted flex-wrap">
                            <div class="flex items-center gap-2">
                                <div class="meta-icon">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                                <time datetime="@post.FrontMatter.Published.ToString("yyyy-MM-ddTHH:mm:ss.fffK", CultureInfo.InvariantCulture)" class="font-medium">
                                    @post.FrontMatter.Published.ToString("MMM d, yyyy", new CultureInfo("en-US"))
                                </time>
                            </div>
                            <span class="inline-flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                <span class="font-medium">@GetReadingTime(post) min read</span>
                            </span>
                        </div>
                    </div>

                    <!-- Content Section -->
                    <div class="flex-1 flex flex-col">
                        <!-- Title -->
                        <h2 class="text-xl lg:text-2xl font-bold leading-tight mb-3">
                            <a class="article-title-link" href="@blazorStaticContentService.Options.PageUrl/@(post.Url)">
                                @post.FrontMatter.Title
                            </a>
                        </h2>

                        <!-- Tags -->
                        <div class="flex flex-wrap gap-2 mb-4">
                            @foreach (var tag in post.FrontMatter.Tags.Take(4))
                            {
                                <a class="skill-tag text-xs uppercase tracking-wider font-semibold" href="@blazorStaticContentService.Options.Tags.TagsPageUrl/@tag">@tag</a>
                            }
                            @if (post.FrontMatter.Tags.Count() > 4)
                            {
                                <span class="skill-tag-muted text-xs font-medium">+@(post.FrontMatter.Tags.Count() - 4)</span>
                            }
                        </div>

                        <!-- Description -->
                        <div class="text-foreground-tertiary text-sm lg:text-base leading-relaxed mb-4 flex-1 line-clamp-3">
                            @((MarkupString)post.FrontMatter.Lead)
                        </div>

                        <!-- Read More Button -->
                        <div class="pt-2">
                            <a class="btn-tertiary group/link inline-flex items-center gap-2 text-sm"
                               aria-label='Read "@(post.FrontMatter.Title)"'
                               href="@blazorStaticContentService.Options.PageUrl/@(post.Url)">
                                <span>Read article</span>
                                <svg class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </article>
        </li>
        index++;
    }
</ul>

@code {
    List<Post<BlogFrontMatter>> posts = new();

    [Parameter] public List<Post<BlogFrontMatter>>? Posts { get; set; }
    [Parameter] public int? MaxPosts { get; set; }

    protected override void OnInitialized()
    {
        posts = Posts != null ? Posts : blazorStaticContentService.Posts;

        if (posts is not null)
        {
            if (MaxPosts.HasValue && MaxPosts > 0)
            {
                posts = posts.OrderByDescending(c => c.FrontMatter.Published).Take(MaxPosts.Value).ToList();
            }
            else
            {
                posts = posts.OrderByDescending(c => c.FrontMatter.Published).ToList();
            }
        }

        base.OnInitialized();
    }

    private string? ExtractFirstImageUrl(string htmlContent)
    {
        if (string.IsNullOrEmpty(htmlContent))
            return null;

        var match = System.Text.RegularExpressions.Regex.Match(htmlContent, "<img[^>]+src=\"([^\"]+)\"[^>]*>", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (match.Success && match.Groups.Count > 1)
        {
            return match.Groups[1].Value;
        }

        return null;
    }

    private int GetReadingTime(Post<BlogFrontMatter> post)
    {
        var text = StripHtml(post.HtmlContent);
        var wordCount = text.Split(new[] { ' ', '\t', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Length;
        return Math.Max(1, (int)Math.Ceiling(wordCount / 225.0));
    }

    private string StripHtml(string html)
    {
        if (string.IsNullOrEmpty(html)) return string.Empty;
        var text = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]+>", string.Empty);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"&\w+;", " ");
        return text;
    }

}
